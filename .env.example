# Copy to .env.local and fill in

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# BBAPI - users provide their own; dev default:
BBAPI_LOGIN=PotatoJunior
BBAPI_CODE=12341234

# BB_PASSWORD - main BuzzerBeater site password (for fetch-player-face / sync-roster-faces).
# NOT the same as BBAPI_CODE. Add to GitHub Secrets for cron; add to .env.local for local runs.
# BB_PASSWORD=

# U21dle (optional)
# U21DLE_MIN_SEASON=60
# U21DLE_MAX_SEASON=70
# U21DLE_MAX_GUESSES=5

# Optional: GitHub for "Suggest a feature" (creates issues via API)
# NEXT_PUBLIC_GITHUB_REPO=owner/repo  (e.g. guygir/bb-fantasy)
# GITHUB_TOKEN=ghp_xxx  (Personal Access Token with repo scope)

# Game
FANTASY_CAP=30
ROSTER_SIZE=5
CURRENT_SEASON=71
NEXT_PUBLIC_CURRENT_SEASON=71
ISRAEL_U21_TEAM_ID=1015
